    {
      "name": "macos-x86_64-debug",
      "configurePreset": "macos-x86_64-debug"
    },
    {
      "name": "macos-universal-release",
      "configurePreset": "macos-universal-release"
    },
    {
      "name": "default-debug",
      "configurePreset": "default-debug"
    }
  ]
}
