* text=auto

# Ensure consistent LF line endings for text files
*.md text eol=lf
*.gd text eol=lf
*.tscn text eol=lf
*.godot text eol=lf
*.gdextension text eol=lf
*.cfg text eol=lf
*.uid text eol=lf

# Treat common binary formats as binary
*.png binary
*.jpg binary
*.jpeg binary
*.wav binary
*.bsp binary
*.mdl binary
*.spr binary
*.wad binary
*.bmp binary
*.dylib binary
*.so binary
*.dll binary
